---
import Layout from "../layouts/Layout.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import InfoBlock from "../components/ui/InfoBlock.astro";
import { storeInfo } from "../data/products.js";
---

<Layout
  title="Nosotros | Pajaritos en la Cabeza"
  description="Conocé la historia y ubicación de Pajaritos en la Cabeza, local de ropa en Trelew, Chubut."
>
  <Header />

  <main>
    <!-- Mini hero -->
    <section
      class="py-14 px-4 text-center text-white"
      style="background-color: #fb8a01"
    >
      <div class="max-w-xl mx-auto">
        <div class="text-5xl mb-4">🐦</div>
        <h1
          class="text-4xl mb-3"
          style="font-family: var(--font-display)"
        >
          Pajaritos en la Cabeza
        </h1>
        <p class="text-white/90 font-semibold text-lg">
          Local físico de ropa y pijamas en Trelew, Chubut, Argentina.
          Estampas coloridas y alegres para toda la familia.
        </p>
      </div>
    </section>

    <!-- Soy Romi -->
    <section class="py-16 px-4" style="background: linear-gradient(135deg, #faf8ff 0%, #fff5eb 100%);">
      <div class="max-w-5xl mx-auto">

        <!-- Título decorativo -->
        <div class="text-center mb-12">
          <p class="text-xs font-black tracking-widest mb-3" style="color: #fb8a01; letter-spacing: 0.15em;">
            LA PERSONA DETRÁS DE TODO
          </p>
          <h2
            class="text-4xl md:text-5xl mb-4 font-black"
            style="font-family: var(--font-display); color: #2d1f5e;"
          >
            ¡Hola! Soy Romi 🧡
          </h2>
          <div class="w-20 h-1 bg-gradient-to-r from-transparent via-brand-orange to-transparent mx-auto rounded-full"></div>
        </div>

        <!-- Grid imagen + texto -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

          <!-- Columna imagen -->
          <div class="order-1 lg:order-1">

            <!-- Contenedor imagen con borde decorativo -->
            <div class="relative max-w-md mx-auto">
              <div
                class="absolute inset-0 rounded-3xl transform rotate-3"
                style="background: linear-gradient(135deg, #c1b3fc 0%, #fb8a01 100%); z-index: -1;"
              ></div>

              <img src="/pajaritosquiensoy.PNG" alt="Romi, fundadora de Pajaritos en la Cabeza" class="w-full rounded-3xl shadow-2xl" />
            </div>

          </div>

          <!-- Columna texto -->
          <div class="order-2 lg:order-2">

            <!-- Intro -->
            <p class="text-lg md:text-xl font-semibold mb-6 leading-relaxed" style="color: #5a4a90;">
              Soy soñadora, apasionada y la creadora de <strong>Pajaritos en la Cabeza</strong>.
              Esposa de un gran compañero y mamá de 3 varones de 19, 6 y 3 años —
              mi mejor profesión sin dudas. ✨
            </p>

            <!-- Mini facts -->
            <div class="grid grid-cols-2 gap-3 mb-6">
              <div class="flex items-center gap-2 text-sm font-bold" style="color: #2d1f5e;">
                🐂 Taurina de pura cepa
              </div>
              <div class="flex items-center gap-2 text-sm font-bold" style="color: #2d1f5e;">
                💜 Casada
              </div>
              <div class="flex items-center gap-2 text-sm font-bold" style="color: #2d1f5e;">
                ☕ Amante del café
              </div>
              <div class="flex items-center gap-2 text-sm font-bold" style="color: #2d1f5e;">
                🎵 Buena música
              </div>
            </div>

            <!-- Historia -->
            <div class="space-y-4 mb-6" style="color: #5a4a90;">
              <p class="leading-relaxed">
                Emprendo hace casi 4 años. Hace un año renuncié a mi trabajo en relación
                de dependencia para dedicarme <strong>100% a este sueño</strong>.
              </p>

              <p class="leading-relaxed">
                Hace 9 meses inauguré mi primer local comercial y desde ese entonces
                mi vida se llenó aún más de magia y amor. 💫
              </p>
            </div>

            <!-- Agradecimiento -->
            <div class="p-5 rounded-2xl mb-6" style="background: rgba(193,179,252,0.15); border-left: 4px solid #c1b3fc;">
              <p class="font-semibold leading-relaxed mb-3" style="color: #2d1f5e;">
                Gracias a todos los que se suman a este proyecto y a los que me siguen
                desde los comienzos en el living de mi casa. 🌈
              </p>

              <p class="font-semibold leading-relaxed" style="color: #2d1f5e;">
                ¡Los esperamos con buena onda, matecitos y los mejores diseños para toda la familia!
              </p>
            </div>

            <!-- CTA Instagram -->
            <a
              href="https://www.instagram.com/pajaritos.enla.cabeza"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 bg-gradient-to-r from-purple-600 to-pink-500 text-white font-black px-6 py-3 rounded-full hover:scale-105 transition shadow-lg"
            >
              📸 Seguinos en Instagram
            </a>

          </div>

        </div>

      </div>
    </section>

    <!-- Info detallada -->
    <section class="max-w-4xl mx-auto px-4 py-12">
      <h2
        class="text-3xl text-brand-text mb-8"
        style="font-family: var(--font-display)"
      >
        📋 Toda la info
      </h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-10">
        <InfoBlock
          emoji="🕐"
          title="Horarios de atención"
          items={[
            `Lunes a viernes: ${storeInfo.hours.weekdays}`,
            `Sábados: ${storeInfo.hours.saturday}`,
          ]}
        />
        <InfoBlock
          emoji="📍"
          title="Dirección"
          items={[
            storeInfo.address,
            "Trelew, Chubut, Argentina",
          ]}
          color="bg-brand-purple-light"
        />
        <InfoBlock
          emoji="💳"
          title="Medios de pago"
          items={storeInfo.payments}
          color="bg-brand-purple-light"
        />
        <InfoBlock
          emoji="🚚"
          title="Opciones de envío"
          items={storeInfo.shipping}
        />
      </div>

      <!-- Mapa Google -->
      <div class="rounded-2xl overflow-hidden shadow-md mb-10">
        <iframe
          src="https://maps.google.com/maps?q=Brown+21,+Trelew,+Chubut,+Argentina&output=embed"
          width="100%"
          height="300"
          style="border:0"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ubicación Pajaritos en la Cabeza"
        ></iframe>
      </div>

      <!-- Social links -->
      <div class="flex flex-wrap gap-4 justify-center">
        <a
          href={`https://wa.me/${storeInfo.whatsapp}`}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 bg-brand-whatsapp text-white font-black px-6 py-3 rounded-full hover:bg-brand-whatsapp-dark transition"
        >
          💬 WhatsApp
        </a>
        <a
          href={`https://instagram.com/${storeInfo.instagram}`}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 bg-brand-orange text-white font-black px-6 py-3 rounded-full hover:bg-brand-orange-dark transition"
        >
          📸 Instagram
        </a>
      </div>
    </section>

    <!-- WhatsApp banner -->
    <section
      class="py-12 px-4 text-center text-white"
      style="background-color: #fb8a01"
    >
      <div class="max-w-xl mx-auto">
        <p class="text-4xl mb-3">💬</p>
        <h2
          class="text-3xl mb-2"
          style="font-family: var(--font-display)"
        >
          ¿Querés contactarnos?
        </h2>
        <p class="text-white/90 mb-6 font-semibold">
          Consultanos por productos, talles, personalizados o envíos.
        </p>
        <a
          href={`https://wa.me/${storeInfo.whatsapp}?text=${encodeURIComponent("¡Hola Pajaritos! Quiero hacer una consulta 🐦")}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block font-black text-lg px-8 py-3 rounded-full hover:scale-105 transition shadow-lg"
          style="background-color: white; color: #fb8a01;"
        >
          Escribir por WhatsApp →
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
