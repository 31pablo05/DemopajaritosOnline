---
import Layout from "../layouts/Layout.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import InfoBlock from "../components/ui/InfoBlock.astro";
import { storeInfo } from "../data/products.js";
---

<Layout
  title="Nosotros | Pajaritos en la Cabeza"
  description="Conocé la historia y ubicación de Pajaritos en la Cabeza, local de ropa en Trelew, Chubut."
>
  <Header />

  <main>
    <!-- Mini hero -->
    <section
      class="py-14 px-4 text-center text-white"
      style="background-color: #fb8a01"
    >
      <div class="max-w-xl mx-auto">
        <div class="text-5xl mb-4">🐦</div>
        <h1
          class="text-4xl mb-3"
          style="font-family: var(--font-display)"
        >
          Pajaritos en la Cabeza
        </h1>
        <p class="text-white/90 font-semibold text-lg">
          Local físico de ropa y pijamas en Trelew, Chubut, Argentina.
          Estampas coloridas y alegres para toda la familia.
        </p>
      </div>
    </section>

    <!-- Info detallada -->
    <section class="max-w-4xl mx-auto px-4 py-12">
      <h2
        class="text-3xl text-brand-text mb-8"
        style="font-family: var(--font-display)"
      >
        📋 Toda la info
      </h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-10">
        <InfoBlock
          emoji="🕐"
          title="Horarios de atención"
          items={[
            `Lunes a viernes: ${storeInfo.hours.weekdays}`,
            `Sábados: ${storeInfo.hours.saturday}`,
          ]}
        />
        <InfoBlock
          emoji="📍"
          title="Dirección"
          items={[
            storeInfo.address,
            "Trelew, Chubut, Argentina",
          ]}
          color="bg-brand-purple-light"
        />
        <InfoBlock
          emoji="💳"
          title="Medios de pago"
          items={storeInfo.payments}
          color="bg-brand-purple-light"
        />
        <InfoBlock
          emoji="🚚"
          title="Opciones de envío"
          items={storeInfo.shipping}
        />
      </div>

      <!-- Mapa Google -->
      <div class="rounded-2xl overflow-hidden shadow-md mb-10">
        <iframe
          src="https://maps.google.com/maps?q=Brown+21,+Trelew,+Chubut,+Argentina&output=embed"
          width="100%"
          height="300"
          style="border:0"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ubicación Pajaritos en la Cabeza"
        ></iframe>
      </div>

      <!-- Social links -->
      <div class="flex flex-wrap gap-4 justify-center">
        <a
          href={`https://wa.me/${storeInfo.whatsapp}`}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 bg-brand-whatsapp text-white font-black px-6 py-3 rounded-full hover:bg-brand-whatsapp-dark transition"
        >
          💬 WhatsApp
        </a>
        <a
          href={`https://instagram.com/${storeInfo.instagram}`}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 bg-brand-orange text-white font-black px-6 py-3 rounded-full hover:bg-brand-orange-dark transition"
        >
          📸 Instagram
        </a>
      </div>
    </section>

    <!-- WhatsApp banner -->
    <section
      class="py-12 px-4 text-center text-white"
      style="background-color: #fb8a01"
    >
      <div class="max-w-xl mx-auto">
        <p class="text-4xl mb-3">💬</p>
        <h2
          class="text-3xl mb-2"
          style="font-family: var(--font-display)"
        >
          ¿Querés contactarnos?
        </h2>
        <p class="text-white/90 mb-6 font-semibold">
          Consultanos por productos, talles, personalizados o envíos.
        </p>
        <a
          href={`https://wa.me/${storeInfo.whatsapp}?text=${encodeURIComponent("¡Hola Pajaritos! Quiero hacer una consulta 🐦")}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block font-black text-lg px-8 py-3 rounded-full hover:scale-105 transition shadow-lg"
          style="background-color: white; color: #fb8a01;"
        >
          Escribir por WhatsApp →
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
