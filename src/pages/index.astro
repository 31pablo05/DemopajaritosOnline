---
import Layout from "../layouts/Layout.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import InfoBlock from "../components/ui/InfoBlock.astro";
import ProductGrid from "../components/islands/ProductGrid.jsx";
import { getFeaturedProducts } from "../lib/sanity.js";
import { categories, storeInfo, formatARS } from "../data/products.js";
const featured = await getFeaturedProducts();
---

<Layout title="Pajaritos en la Cabeza | Tienda Online">
  <Header />

  <main>
    <!-- Hero -->
    <section
      class="relative overflow-hidden text-white min-h-screen flex items-center justify-center px-4 text-center bg-cover bg-center bg-no-repeat hero-section"
      style="background-image: url('/hero/herodesktop3.jpg'); background-color: #fb8a01;"
    >
      <!-- Overlay naranja semitransparente para legibilidad -->
      <div
        aria-hidden="true"
        class="absolute inset-0 z-0"
        style="background-color: rgba(251, 138, 1, 0.55);"
      ></div>

      <div class="max-w-2xl mx-auto relative z-10 w-full">
        <h1
          class="text-4xl md:text-5xl mb-4 leading-tight"
          style="font-family: var(--font-display); text-shadow: 0 0 18px rgba(193,179,252,0.9), 0 0 40px rgba(193,179,252,0.55), 2px 2px 0 rgba(107,79,192,0.35), -1px -1px 0 rgba(107,79,192,0.25);"
        >
          Pajaritos en la Cabeza
        </h1>
        <p
          class="text-white text-lg mb-8 font-semibold"
          style="text-shadow: 0 0 14px rgba(193,179,252,0.85), 0 0 30px rgba(193,179,252,0.45), 1px 1px 0 rgba(107,79,192,0.3);"
        >
          Estampas coloridas para toda la familia<br />
          Pijamas, remeras y más desde Trelew, Chubut.
        </p>

        <!-- Badges -->
        <div class="flex flex-wrap gap-2 justify-center mb-8">
          <span class="px-4 py-2 rounded-full text-sm font-bold border border-white/40" style="background: rgba(255,255,255,0.15)">
            📦 Envío gratis en Trelew
          </span>
          <span class="px-4 py-2 rounded-full text-sm font-bold border border-white/40" style="background: rgba(255,255,255,0.15)">
            🚚 Todo el país
          </span>
          <span class="px-4 py-2 rounded-full text-sm font-bold border border-white/40" style="background: rgba(255,255,255,0.15)">
            💳 3 cuotas sin interés
          </span>
        </div>

        <a
          href="/tienda"
          class="inline-block font-black text-lg px-8 py-3 rounded-full shadow-lg hover:scale-105 transition"
          style="background-color: white; color: #fb8a01;"
        >
          Ver catálogo completo →
        </a>
      </div>

      <!-- Flecha de scroll animada -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 scroll-arrow" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 5v14M5 12l7 7 7-7"/>
        </svg>
      </div>
    </section>

    <!-- Strip de beneficios -->
    <div style="background: #2d1f5e;" class="py-4 px-4">
      <div class="max-w-6xl mx-auto flex flex-wrap justify-center gap-x-8 gap-y-3">
        <div class="flex items-center gap-2 text-white font-bold text-sm">
          <span style="color: #fb8a01; font-size: 1.2rem;">📦</span> Envío gratis en Trelew
        </div>
        <div class="flex items-center gap-2 text-white font-bold text-sm">
          <span style="color: #fb8a01; font-size: 1.2rem;">🚚</span> Enviamos a todo el país
        </div>
        <div class="flex items-center gap-2 text-white font-bold text-sm">
          <span style="color: #fb8a01; font-size: 1.2rem;">💳</span> Hasta 3 cuotas sin interés
        </div>
        <div class="flex items-center gap-2 text-white font-bold text-sm">
          <span style="color: #fb8a01; font-size: 1.2rem;">🎨</span> Diseños exclusivos
        </div>
        <div class="flex items-center gap-2 text-white font-bold text-sm">
          <span style="color: #fb8a01; font-size: 1.2rem;">💬</span> Atención personalizada
        </div>
      </div>
    </div>

    <!-- Categorías visuales -->
    <section class="max-w-6xl mx-auto px-4 pt-12 pb-4">
      <h2 class="text-3xl text-brand-text mb-2 text-center" style="font-family: var(--font-display)">
        ¿Qué estás buscando?
      </h2>
      <p class="text-brand-text-muted text-center mb-8 font-semibold">Explorá nuestras categorías</p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <a href="/tienda" class="category-card group flex flex-col items-center gap-3 py-8 px-4 rounded-3xl text-center transition-all duration-200 hover:-translate-y-1" style="background: linear-gradient(135deg, #c1b3fc 0%, #a99bf0 100%); box-shadow: 0 4px 20px rgba(193,179,252,0.4);">
          <span style="font-size: 2.8rem; line-height:1;">😴</span>
          <span class="font-black text-lg" style="color: #2d1f5e;">Pijamas</span>
          <span class="text-xs font-bold" style="color: #5a4a90;">Para toda la familia</span>
        </a>
        <a href="/tienda" class="category-card group flex flex-col items-center gap-3 py-8 px-4 rounded-3xl text-center transition-all duration-200 hover:-translate-y-1" style="background: linear-gradient(135deg, #fb8a01 0%, #e07a00 100%); box-shadow: 0 4px 20px rgba(251,138,1,0.35);">
          <span style="font-size: 2.8rem; line-height:1;">👕</span>
          <span class="font-black text-lg text-white">Remeras</span>
          <span class="text-xs font-bold text-white/80">Estampas únicas</span>
        </a>
        <a href="/tienda" class="category-card group flex flex-col items-center gap-3 py-8 px-4 rounded-3xl text-center transition-all duration-200 hover:-translate-y-1" style="background: linear-gradient(135deg, #fb8a01 0%, #e07a00 100%); box-shadow: 0 4px 20px rgba(251,138,1,0.35);">
          <span style="font-size: 2.8rem; line-height:1;">🛏️</span>
          <span class="font-black text-lg text-white">Cubrecamas</span>
          <span class="text-xs font-bold text-white/80">Para tu cuarto</span>
        </a>
        <a href="/tienda" class="category-card group flex flex-col items-center gap-3 py-8 px-4 rounded-3xl text-center transition-all duration-200 hover:-translate-y-1" style="background: linear-gradient(135deg, #c1b3fc 0%, #a99bf0 100%); box-shadow: 0 4px 20px rgba(193,179,252,0.4);">
          <span style="font-size: 2.8rem; line-height:1;">🎁</span>
          <span class="font-black text-lg" style="color: #2d1f5e;">Sets</span>
          <span class="text-xs font-bold" style="color: #5a4a90;">Combo ideal de regalo</span>
        </a>
      </div>
    </section>

    <!-- Featured products -->
    <section class="max-w-6xl mx-auto px-4 py-12">      <h2
        class="text-3xl text-brand-text mb-2"
        style="font-family: var(--font-display)"
      >
        ⭐ Productos destacados
      </h2>
      <p class="text-brand-text-muted mb-6 font-semibold">Los favoritos de nuestros clientes</p>

      <ProductGrid
        client:load
        products={featured}
        categories={[{ id: "todos", label: "Todos", emoji: "⭐" }]}
      />

      <div class="text-center mt-8">
        <a
          href="/tienda"
          class="inline-block bg-brand-orange text-white font-black px-8 py-3 rounded-full hover:bg-brand-orange-dark transition"
        >
          Ver todos los productos →
        </a>
      </div>
    </section>

    <!-- Personalización banner -->
    <section class="px-4 py-14" style="background: linear-gradient(135deg, #2d1f5e 0%, #3d2a7e 100%);">
      <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center gap-8">
        <div class="text-6xl md:text-8xl flex-shrink-0" style="line-height:1;">🎨</div>
        <div class="flex-1 text-center md:text-left">
          <p class="font-black text-sm tracking-widest mb-2" style="color: #c1b3fc;">SERVICIO ESPECIAL</p>
          <h2 class="text-3xl md:text-4xl text-white mb-3" style="font-family: var(--font-display);">
            ¡Personalizamos para vos!
          </h2>
          <p class="mb-6 font-semibold" style="color: rgba(255,255,255,0.75);">
            Estampas con tu diseño, nombre o personaje favorito. Ideal para regalos, cumpleaños o pedidos en grupo. ¡Contanos tu idea y lo hacemos realidad!
          </p>
          <a
            href={`https://wa.me/${storeInfo.whatsapp}?text=${encodeURIComponent("Hola! Me interesa un pedido personalizado 🎨")}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 font-black text-base px-7 py-3 rounded-full hover:scale-105 transition"
            style="background: #fb8a01; color: white; box-shadow: 0 4px 20px rgba(251,138,1,0.4);"
          >
            Consultá por WhatsApp →
          </a>
        </div>
      </div>
    </section>

    <!-- Testimonios -->
    <section class="py-14 px-4" style="background: #faf8ff;">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl text-brand-text mb-2 text-center" style="font-family: var(--font-display);">
          ❤️ Lo que dicen nuestros clientes
        </h2>
        <p class="text-brand-text-muted text-center mb-10 font-semibold">Familias de Trelew y de toda la Argentina</p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="bg-white rounded-3xl p-6 shadow-sm" style="border: 1.5px solid #ede8ff;">
            <div class="flex gap-1 mb-3">{"⭐⭐⭐⭐⭐"}</div>
            <p class="font-semibold mb-4" style="color: #5a4a90;">"Le compré el pijama de dinosaurio a mi hijo y quedó re feliz. Muy buena calidad y llegó rapidísimo. ¡Ya vamos por el segundo!"</p>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full font-black text-white flex items-center justify-center text-sm" style="background: #c1b3fc; color: #2d1f5e;">MA</div>
              <div>
                <p class="font-black text-sm" style="color: #2d1f5e;">María A.</p>
                <p class="text-xs" style="color: #7a6aaa;">Trelew, Chubut</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-3xl p-6 shadow-sm" style="border: 1.5px solid #ede8ff;">
            <div class="flex gap-1 mb-3">{"⭐⭐⭐⭐⭐"}</div>
            <p class="font-semibold mb-4" style="color: #5a4a90;">"Pedí remeras personalizadas para el cumple de mi nena. Me ayudaron con el diseño, quedaron hermosas. Todos los invitados preguntaron dónde las compré."</p>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full font-black flex items-center justify-center text-sm" style="background: #fb8a01; color: white;">CG</div>
              <div>
                <p class="font-black text-sm" style="color: #2d1f5e;">Carolina G.</p>
                <p class="text-xs" style="color: #7a6aaa;">Rawson, Chubut</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-3xl p-6 shadow-sm" style="border: 1.5px solid #ede8ff;">
            <div class="flex gap-1 mb-3">{"⭐⭐⭐⭐⭐"}</div>
            <p class="font-semibold mb-4" style="color: #5a4a90;">"Compré el set pijama + remera como regalo de Navidad. El packaging es re lindo y la calidad excelente. Lo recomiendo sin dudarlo."</p>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full font-black flex items-center justify-center text-sm" style="background: #c1b3fc; color: #2d1f5e;">LR</div>
              <div>
                <p class="font-black text-sm" style="color: #2d1f5e;">Lucas R.</p>
                <p class="text-xs" style="color: #7a6aaa;">Buenos Aires</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Info grid -->
    <section class="bg-white py-12 px-4">      <div class="max-w-6xl mx-auto">
        <h2
          class="text-3xl text-brand-text mb-8 text-center"
          style="font-family: var(--font-display)"
        >
          📍 Info del local
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <InfoBlock
            emoji="🕐"
            title="Horarios"
            items={[
              `Lunes a viernes: ${storeInfo.hours.weekdays}`,
              `Sábados: ${storeInfo.hours.saturday}`,
            ]}
          />
          <InfoBlock
            emoji="📍"
            title="Dónde estamos"
            items={[storeInfo.address]}
            color="bg-brand-purple-light"
          />
          <InfoBlock
            emoji="💳"
            title="Medios de pago"
            items={storeInfo.payments}
            color="bg-brand-purple-light"
          />
          <InfoBlock
            emoji="🚚"
            title="Envíos"
            items={storeInfo.shipping}
          />
        </div>
      </div>
    </section>

    <!-- WhatsApp banner -->
    <section
      class="py-12 px-4 text-center text-white"
      style="background-color: #fb8a01"
    >
      <div class="max-w-xl mx-auto">
        <p class="text-4xl mb-3">💬</p>
        <h2
          class="text-3xl mb-2"
          style="font-family: var(--font-display)"
        >
          ¿Tenés alguna consulta?
        </h2>
        <p class="text-white/90 mb-6 font-semibold">
          Escribinos por WhatsApp y te respondemos al toque.
        </p>
        <a
          href={`https://wa.me/${storeInfo.whatsapp}?text=${encodeURIComponent("¡Hola Pajaritos! Quiero consultar sobre sus productos 🐦")}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block font-black text-lg px-8 py-3 rounded-full hover:scale-105 transition shadow-lg"
          style="background-color: white; color: #fb8a01;"
        >
          Escribir por WhatsApp →
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* Hero mobile: imagen diferente en pantallas pequeñas */
  @media (max-width: 767px) {
    .hero-section {
      background-image: url('/hero/heromobile.jpg') !important;
    }
  }
</style>

