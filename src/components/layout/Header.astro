---
import CartWidget from "../islands/CartWidget.jsx";

const navLinks = [
  { href: "/", label: "Inicio", emoji: "🏠" },
  { href: "/tienda", label: "Tienda", emoji: "🛍️", badge: "NUEVO" },
  { href: "/nosotros", label: "Nosotros", emoji: "🐦" },
];

const currentPath = Astro.url.pathname;
---

<header
  id="main-header"
  class="sticky top-0 z-30"
  style="background: white; box-shadow: 0 2px 16px rgba(251,138,1,0.1);"
>
  <!-- Barra de anuncio (se oculta al hacer scroll) -->
  <div
    id="announcement-bar"
    aria-label="Información de la tienda"
    style="
      background: linear-gradient(90deg, #e07a00 0%, #fb8a01 45%, #e07a00 100%);
      color: white;
      text-align: center;
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.04em;
      padding: 7px 16px;
      overflow: hidden;
      max-height: 36px;
      opacity: 1;
      white-space: nowrap;
      transition: max-height 0.32s ease, opacity 0.22s ease, padding 0.32s ease;
    "
  >
    <span>📍 Brown 21, Local 2 — Trelew, Chubut</span>
    <span style="margin: 0 10px; opacity: 0.38;">|</span>
    <span>✨ Envíos a todo Chubut</span>
    <span style="margin: 0 10px; opacity: 0.38;">|</span>
    <span>💬 Pedís por WhatsApp</span>
  </div>

  <!-- Main row -->
  <div class="max-w-6xl mx-auto px-4 py-1.5 flex items-center justify-between gap-4">

    <!-- Logo -->
    <a href="/" class="shrink-0 logo-entrance">
      <img
        src="/logopajaritos.PNG"
        alt="Pajaritos en la Cabeza"
        class="h-16 md:h-20 w-auto object-contain logo-hover"
      />
    </a>

    <!-- Nav desktop (hidden en mobile) -->
    <nav class="hidden md:flex items-center gap-1" aria-label="Navegación principal">
      {navLinks.map((link, i) => (
        <a
          href={link.href}
          class={`nav-item relative px-5 py-2 rounded-full font-black text-sm transition-all duration-200 group ${
            currentPath === link.href
              ? "bg-brand-orange text-white nav-active"
              : "text-brand-text hover:bg-brand-orange-light hover:text-brand-orange hover:-translate-y-0.5"
          }`}
          style={`animation-delay: ${i * 75}ms`}
        >
          <span class="mr-1.5 text-xs">{link.emoji}</span>
          {link.label}
          {link.badge && (
            <span
              class="absolute -top-2 -right-1 font-black rounded-full px-1.5"
              style="font-size: 0.55rem; background: #c1b3fc; color: #2d1f5e; letter-spacing: 0.04em; line-height: 1.8;"
            >
              {link.badge}
            </span>
          )}
          {currentPath !== link.href && (
            <span class="absolute bottom-1 left-1/2 -translate-x-1/2 h-0.5 w-0 rounded-full bg-brand-orange transition-all duration-200 group-hover:w-4/5" />
          )}
        </a>
      ))}
    </nav>

    <!-- Derecha: carrito + hamburguesa -->
    <div class="flex items-center gap-2 shrink-0">
      <CartWidget client:load />

      <!-- Hamburguesa (solo mobile) -->
      <button
        id="hamburger-btn"
        class="md:hidden flex flex-col items-center justify-center gap-[5px] w-10 h-10 rounded-xl border-2 transition-all duration-200 hover:bg-brand-orange-light"
        style="border-color: #fb8a01;"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="hb-bar w-[18px] h-[2.5px] rounded-full transition-all duration-300 origin-center" style="background:#fb8a01;"></span>
        <span class="hb-bar w-[18px] h-[2.5px] rounded-full transition-all duration-300 origin-center" style="background:#fb8a01;"></span>
        <span class="hb-bar w-[18px] h-[2.5px] rounded-full transition-all duration-300 origin-center" style="background:#fb8a01;"></span>
      </button>
    </div>
  </div>

  <!-- Línea naranja degradada -->
  <div
    aria-hidden="true"
    style="
      height: 2px;
      background: linear-gradient(
        90deg,
        transparent 0%,
        rgba(251,138,1,0.35) 15%,
        #fb8a01 50%,
        rgba(251,138,1,0.35) 85%,
        transparent 100%
      );
    "
  ></div>

  <!-- Glow naranja debajo de la navbar -->
  <div
    aria-hidden="true"
    class="absolute left-0 right-0 pointer-events-none"
    style="
      bottom: -14px;
      height: 14px;
      background: linear-gradient(to bottom, rgba(251,138,1,0.16), transparent);
    "
  ></div>

  <!-- Menú mobile dropdown -->
  <div
    id="mobile-menu"
    class="md:hidden overflow-hidden"
    style="max-height:0; opacity:0; transition: max-height 0.38s cubic-bezier(0.4,0,0.2,1), opacity 0.25s ease;"
    aria-hidden="true"
  >
    <nav
      class="px-4 pt-3 pb-5 flex flex-col gap-2"
      style="border-top: 1.5px solid rgba(251,138,1,0.18); background: linear-gradient(180deg, #fff 0%, #faf8ff 100%);"
      aria-label="Menú mobile"
    >
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={`flex items-center gap-3 px-5 py-3.5 rounded-2xl font-black text-sm transition-all duration-200 ${
            currentPath === link.href
              ? "text-white"
              : "text-brand-text hover:bg-brand-orange-light hover:text-brand-orange hover:translate-x-1"
          }`}
          style={
            currentPath === link.href
              ? "background: linear-gradient(135deg, #fb8a01 0%, #e07a00 100%); box-shadow: 0 4px 14px rgba(251,138,1,0.35);"
              : ""
          }
        >
          <span class="text-lg leading-none">{link.emoji}</span>
          <span class="flex-1">{link.label}</span>
          {link.badge && currentPath !== link.href && (
            <span
              class="font-black rounded-full px-2 py-0.5"
              style="font-size: 0.6rem; background: #c1b3fc; color: #2d1f5e; letter-spacing: 0.04em;"
            >
              {link.badge}
            </span>
          )}
          {currentPath === link.href && (
            <span class="text-white/70 text-xs">activo ✓</span>
          )}
        </a>
      ))}

      <!-- Tagline de tienda -->
      <div style="border-top: 1px solid rgba(193,179,252,0.35); margin-top: 6px; padding-top: 12px; text-align: center;">
        <p style="font-size: 0.7rem; color: #7a6aaa; font-weight: 700; letter-spacing: 0.04em;">
          🐦 Pajaritos en la Cabeza · Trelew, Chubut
        </p>
      </div>
    </nav>
  </div>
</header>

<style>
  /* Animación de entrada del logo */
  @keyframes logoEntrance {
    from {
      opacity: 0;
      transform: scale(0.82) translateX(-6px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateX(0);
    }
  }

  /* Animación de entrada de los nav links */
  @keyframes navItemIn {
    from {
      opacity: 0;
      transform: translateY(-7px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .logo-entrance {
    animation: logoEntrance 0.45s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }

  .logo-hover {
    transition: transform 0.32s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .logo-entrance:hover .logo-hover {
    transform: scale(1.07) rotate(-3deg);
  }

  .nav-item {
    animation: navItemIn 0.35s ease-out both;
  }

  /* Glow en el link activo desktop */
  .nav-active {
    box-shadow: 0 4px 16px rgba(251, 138, 1, 0.42);
  }

  /* Hamburguesa → X */
  #hamburger-btn.is-open .hb-bar:nth-child(1) {
    transform: translateY(7.5px) rotate(45deg);
  }
  #hamburger-btn.is-open .hb-bar:nth-child(2) {
    transform: scaleX(0);
    opacity: 0;
  }
  #hamburger-btn.is-open .hb-bar:nth-child(3) {
    transform: translateY(-7.5px) rotate(-45deg);
  }

  /* Glassmorphism + sombra naranja al hacer scroll */
  #main-header.is-scrolled {
    background: rgba(255, 255, 255, 0.9) !important;
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    box-shadow: 0 4px 28px rgba(251, 138, 1, 0.22) !important;
  }
</style>

<script>
  const btn = document.getElementById("hamburger-btn");
  const menu = document.getElementById("mobile-menu");
  const header = document.getElementById("main-header");
  const announcementBar = document.getElementById("announcement-bar");

  function openMenu() {
    if (!btn || !menu) return;
    btn.classList.add("is-open");
    btn.setAttribute("aria-expanded", "true");
    menu.setAttribute("aria-hidden", "false");
    menu.style.maxHeight = menu.scrollHeight + "px";
    menu.style.opacity = "1";
  }

  function closeMenu() {
    if (!btn || !menu) return;
    btn.classList.remove("is-open");
    btn.setAttribute("aria-expanded", "false");
    menu.setAttribute("aria-hidden", "true");
    menu.style.maxHeight = "0";
    menu.style.opacity = "0";
  }

  btn?.addEventListener("click", () => {
    btn.classList.contains("is-open") ? closeMenu() : openMenu();
  });

  // Cerrar al hacer click en un link del menú
  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", closeMenu);
  });

  // Cerrar si se agranda la ventana a desktop
  window.addEventListener(
    "resize",
    () => {
      if (window.innerWidth >= 768) closeMenu();
    },
    { passive: true }
  );

  // Glassmorphism + ocultar barra de anuncio al hacer scroll
  window.addEventListener(
    "scroll",
    () => {
      const isScrolled = window.scrollY > 8;
      header?.classList.toggle("is-scrolled", isScrolled);
      if (announcementBar) {
        if (isScrolled) {
          announcementBar.style.maxHeight = "0";
          announcementBar.style.opacity = "0";
          announcementBar.style.paddingTop = "0";
          announcementBar.style.paddingBottom = "0";
        } else {
          announcementBar.style.maxHeight = "36px";
          announcementBar.style.opacity = "1";
          announcementBar.style.paddingTop = "7px";
          announcementBar.style.paddingBottom = "7px";
        }
      }
    },
    { passive: true }
  );
</script>